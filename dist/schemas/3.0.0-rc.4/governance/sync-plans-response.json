{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/schemas/3.0.0-rc.4/governance/sync-plans-response.json",
  "title": "Sync Plans Response",
  "description": "Response from syncing campaign plans. Returns status and active validation categories for each plan.",
  "type": "object",
  "properties": {
    "plans": {
      "type": "array",
      "description": "Status for each synced plan.",
      "items": {
        "type": "object",
        "properties": {
          "plan_id": {
            "type": "string",
            "description": "Plan identifier."
          },
          "status": {
            "type": "string",
            "enum": ["active", "error"],
            "description": "Sync result status. 'active' means sync succeeded; 'error' means sync failed."
          },
          "version": {
            "type": "integer",
            "description": "Plan version (increments on each sync)."
          },
          "categories": {
            "type": "array",
            "description": "Validation categories active for this plan.",
            "items": {
              "type": "object",
              "properties": {
                "category_id": {
                  "type": "string",
                  "description": "Validation category identifier."
                },
                "status": {
                  "type": "string",
                  "enum": ["active", "inactive"],
                  "description": "Whether this category is active for this plan."
                }
              },
              "required": ["category_id", "status"],
              "additionalProperties": false
            }
          },
          "resolved_policies": {
            "type": "array",
            "description": "Policies the governance agent will enforce for this plan. Includes explicitly referenced policies from the brand compliance configuration and auto-applied policies matched by jurisdiction or policy category. Present when the governance agent supports policy resolution.",
            "items": {
              "type": "object",
              "properties": {
                "policy_id": {
                  "type": "string",
                  "description": "Registry policy ID."
                },
                "source": {
                  "type": "string",
                  "enum": ["explicit", "auto_applied"],
                  "description": "How this policy was included. 'explicit': referenced in the brand compliance configuration. 'auto_applied': matched automatically by jurisdiction or policy category."
                },
                "enforcement": {
                  "$ref": "/schemas/3.0.0-rc.4/enums/policy-enforcement.json",
                  "description": "Enforcement level for this policy."
                },
                "reason": {
                  "type": "string",
                  "description": "Why this policy was included (e.g., 'Matched jurisdiction US and policy category pharmaceutical_advertising')."
                }
              },
              "required": ["policy_id", "source", "enforcement"],
              "additionalProperties": false
            }
          }
        },
        "required": ["plan_id", "status", "version"],
        "additionalProperties": false
      }
    }
  },
  "required": ["plans"],
  "additionalProperties": false
}
