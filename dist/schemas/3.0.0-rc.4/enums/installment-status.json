{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/schemas/3.0.0-rc.4/enums/installment-status.json",
  "title": "Installment Status",
  "description": "Lifecycle status of an installment",
  "type": "string",
  "enum": [
    "scheduled",
    "tentative",
    "live",
    "postponed",
    "cancelled",
    "aired",
    "published"
  ],
  "enumDescriptions": {
    "scheduled": "Confirmed, will happen as planned",
    "tentative": "May not happen (e.g., playoff Game 7 depends on Game 6)",
    "live": "Currently airing or streaming right now",
    "postponed": "Was scheduled but delayed to a future date",
    "cancelled": "Will not happen",
    "aired": "Already broadcast (live/linear content)",
    "published": "Already released (on-demand content)"
  }
}
